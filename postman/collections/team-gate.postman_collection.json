{
  "info": {
    "_postman_id": "team-gate-lab05-compose",
    "name": "FIT4110 Lab05 - Team Gate - Access Gate Compose",
    "description": "Postman/Newman tests for Lab 05 Docker Compose stack: Access Gate API + PostgreSQL + AI/Risk Scoring service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Compose_Health",
      "item": [
        {
          "name": "01 API health returns database ok",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('API status is ok', function () {",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});",
                  "",
                  "pm.test('Service is access-gate', function () {",
                  "  pm.expect(json.service).to.eql('access-gate');",
                  "});",
                  "",
                  "pm.test('Database status is ok when required', function () {",
                  "  if (json.database && json.database.required === true) {",
                  "    pm.expect(json.database.status).to.eql('ok');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "02 AI service health returns ok",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{aiServiceUrl}}/health",
              "host": [
                "{{aiServiceUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('AI service health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('AI service status is ok', function () {",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});",
                  "",
                  "pm.test('AI service has service name', function () {",
                  "  pm.expect(json.service).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]

    {
      "name": "04_AI_Risk_Service",
      "item": [
        {
          "name": "10 AI predict active card low risk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": \"card-001\",\n  \"gateId\": \"gate-main\",\n  \"direction\": \"IN\"\n}"
            },
            "url": {
              "raw": "{{aiServiceUrl}}/predict",
              "host": [
                "{{aiServiceUrl}}"
              ],
              "path": [
                "predict"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('AI predict returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Active card has LOW risk', function () {",
                  "  pm.expect(json.riskLevel).to.eql('LOW');",
                  "});",
                  "",
                  "pm.test('AI response has modelVersion', function () {",
                  "  pm.expect(json.modelVersion).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },

      "item": [
        {
          "name": "03 Get recent access logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "X-Correlation-Id",
                "value": "11111111-1111-1111-1111-111111111111"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "access",
                "logs",
                "recent"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Recent logs returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Recent logs has items array', function () {",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Recent logs has pagination fields', function () {",
                  "  pm.expect(json).to.have.property('hasMore');",
                  "  pm.expect(json).to.have.property('nextCursor');",
                  "});"
                ]
              }
            }
          ]
        },

{
  "name": "fit4110-lab05-access-gate-compose-readiness",
  "version": "0.1.0",
  "description": "FIT4110 Lab 05 - Docker Compose readiness for Access Gate service",
  "private": true,
  "scripts": {
    "lint:openapi": "spectral lint contracts/*.yaml --ruleset .spectral.yaml",
    "test:compose": "newman run postman/collections/team-gate.postman_collection.json -e postman/environments/team-gate_local.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-lab05-compose.xml --reporter-htmlextra-export reports/newman-lab05-compose.html",
    "compose:up": "docker compose up -d --build --wait",
    "compose:down": "docker compose down",
    "compose:down:volumes": "docker compose down -v",
    "compose:ps": "docker compose ps",
    "compose:logs": "docker compose logs"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.10.0",
    "@stoplight/spectral-cli": "^6.13.1",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}
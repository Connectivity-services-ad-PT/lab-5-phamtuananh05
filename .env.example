# API configuration
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=lab-token
SERVICE_NAME=access-gate
SERVICE_VERSION=0.5.0
ENV=local

# PostgreSQL configuration for Docker Compose
POSTGRES_USER=access_gate_user
POSTGRES_PASSWORD=access_gate_password
POSTGRES_DB=access_gate_db

# Database configuration for Access Gate API
DB_REQUIRED=true
DB_HOST=db
DB_PORT=5432
DB_NAME=access_gate_db
DB_USER=access_gate_user
DB_PASSWORD=access_gate_password

# AI/Risk Scoring service configuration
AI_SERVICE_BASE_URL=http://ai-service:9000

# Optional inter-service configuration
CORE_BUSINESS_BASE_URL=http://host.docker.internal:4011
CORE_BUSINESS_TOKEN=lab-token